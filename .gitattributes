# Git-Crypt Encryption Rules
# ==========================
# Files and patterns that should be encrypted with git-crypt
#
# Usage:
#   1. Initialize git-crypt: git-crypt init
#   2. Add your GPG key: git-crypt add-gpg-user <your-email>
#   3. Files matching these patterns will be automatically encrypted

# AWS - Credentials and config contain account IDs
home/aws/config/credentials filter=git-crypt diff=git-crypt
home/aws/config/config filter=git-crypt diff=git-crypt

# SSH - Internal network topology, hostnames, IPs
home/ssh/default.nix filter=git-crypt diff=git-crypt

# AI Preferences - Jira cloud IDs, org-specific config
home/ai/4-preferences.yaml filter=git-crypt diff=git-crypt

# Viscosity VPN - private keys, certs, endpoint topology
home/viscosity/configs/** filter=git-crypt diff=git-crypt
